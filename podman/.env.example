# Template for the plaintext "Option B" setup. The RECOMMENDED path (Option A)
# keeps secrets in the Docker secret store instead of this file — see the README.
# Use this file only if you run the container directly with `--env-file`:
# copy it to `.env`, fill in real values, and `chmod 600 .env`.
#
# Do NOT commit a real API key (.env is git-ignored), and never paste these
# values into Claude Desktop's config file.

# Hostname or IP address of your Palo Alto firewall's management interface.
PANOS_HOST=firewall.example.com

# PAN-OS API key. Generate it out of band with curl (see README, Step 0).
PANOS_API_KEY=replace-with-your-key

# TLS verification:
#   yes (default) — verify the firewall's TLS certificate
#   no            — skip verification; only acceptable for self-signed lab certs
PANOS_VERIFY_SSL=yes

# Virtual system to operate on. Single-vsys firewalls use vsys1 (the default).
PANOS_VSYS=vsys1

# Write mode. This server can MODIFY firewall configuration.
#   yes (default) — create/edit/delete and commit tools are active
#   no            — write/commit tools refuse; behaves read-only
PANOS_ENABLE_WRITE=yes
